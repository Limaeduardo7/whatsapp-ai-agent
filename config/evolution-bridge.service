[Unit]
Description=WhatsApp AI Agent - Evolution Bridge
After=network.target

[Service]
User=root
WorkingDirectory=/root/clawd/projects/whatsapp-ai-agent
Environment="PATH=/usr/local/bin"
EnvironmentFile=/root/clawd/projects/whatsapp-ai-agent/.env
ExecStart=/usr/local/bin/python3 -m uvicorn src.main:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=5
KillMode=mixed

[Install]
WantedBy=multi-user.target
