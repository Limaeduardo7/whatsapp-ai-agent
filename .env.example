# Evolution API Configuration
EVOLUTION_BASE_URL=https://your-evolution-api.com
EVOLUTION_INSTANCE=default
EVOLUTION_API_KEY=your_api_key_here
EVOLUTION_WEBHOOK_SECRET=change_me_for_evolution_webhook

# LLM Configuration (Kimi 2.5 via NVIDIA)
LLM_API_URL=http://localhost:18789/v1/chat/completions
LLM_API_KEY=your_llm_key_here
LLM_MODEL_ID=nvidia-kimi/moonshotai/kimi-k2.5
THINKING_LEVEL=high

# Gemini Configuration (STT/Vision)
GEMINI_API_KEY=your_gemini_key_here
GEMINI_STT_MODEL=gemini-1.5-flash

# Notifications (Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_IDS=-1001234567890,-3726083368

# Paths
AGENTS_DIR=/root/.openclaw/agents
WORKSPACE_DIR=/root/clawd
CLIENTS_DIR=/root/clawd/clients

# Data Storage
MEMORY_FILE=./data/chat_memory.json
BLACKLIST_FILE=./data/ignored_numbers.json
DB_PATH=./data/agent.db
LOG_FILE=./logs/app.log
CORS_ORIGINS=*
ADMIN_API_KEY=change_me_for_admin_routes

# Owner WhatsApp number for alerts
OWNER_NUMBER=5554999999999

# Notion Integration (optional)
NOTION_API_KEY=your_notion_key
NOTION_DATABASE_ID=your_database_id

# Hotmart Marketing Automation
HOTMART_WEBHOOK_SECRET=your_hotmart_webhook_secret
SEQUENCES_FILE=./data/automation_sequences.json
SCHEDULER_INTERVAL_SECONDS=30
HOTMART_CLIENT_ID=
HOTMART_CLIENT_SECRET=
HOTMART_BASIC_TOKEN=
